<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-pwa="admin">
  <head>
    <%= render "layouts/head", manifest: false, theme_color: "#f8fafc", stylesheets: %w[application admin], javascript_assets: %w[admin] %>
  </head>

  <body class="admin-shell">
    <% manager_name = manager_display_name(@manager) %>

    <aside class="admin-sidebar">
      <%= link_to admin_root_path, class: "brand-mark admin-brand" do %>
        <span class="brand-dot"></span>
        <span><%= t("app.name") %></span>
      <% end %>

      <nav class="admin-nav" aria-label="<%= t("admin.nav.label") %>">
        <%= link_to t("admin.nav.dashboard"), admin_root_path, class: nav_item_class(admin_root_path, exact: true) %>
        <%= link_to t("admin.nav.employees"), admin_employees_path, class: nav_item_class(admin_employees_path) %>
        <%= link_to t("admin.nav.corrections"), admin_corrections_path, class: nav_item_class(admin_corrections_path) %>
        <%= link_to t("admin.nav.reports"), admin_reports_path, class: nav_item_class(admin_reports_path) %>
      </nav>
    </aside>

    <div class="admin-workspace">
      <header class="admin-header">
        <div>
          <p class="eyebrow"><%= t("admin.area") %></p>
          <strong><%= manager_name %></strong>
        </div>
        <div class="admin-profile">
          <span><%= t("admin.role") %></span>
          <span class="avatar avatar-small"><%= initials(manager_name) %></span>
        </div>
      </header>

      <% flash.each do |type, message| %>
        <div class="flash flash-<%= type %>"><%= message %></div>
      <% end %>

      <main class="admin-main">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
