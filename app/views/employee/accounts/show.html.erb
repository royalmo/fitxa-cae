<% content_for :title, t(".title") %>

<section class="page-intro">
  <div>
    <h1 class="page-title"><%= icon "user", class: "icon-large" %><span><%= t(".heading") %></span></h1>
    <p><%= t(".intro") %></p>
  </div>
</section>

<div class="employee-grid">
  <section class="panel">
    <div class="panel-heading">
      <h2 class="panel-title"><%= icon "user" %><span><%= t(".personal_data") %></span></h2>
    </div>

    <dl class="detail-list">
      <div>
        <dt><%= icon "user", class: "icon-muted" %><span><%= t(".name") %></span></dt>
        <dd><%= employee_display_name(@employee) %></dd>
      </div>
      <div>
        <dt><%= icon "badge-check", class: "icon-muted" %><span><%= t(".national_id") %></span></dt>
        <dd><%= @employee.national_id %></dd>
      </div>
      <div>
        <dt><%= icon "mail", class: "icon-muted" %><span><%= t(".email") %></span></dt>
        <dd><%= @employee.email.presence || t(".empty_value") %></dd>
      </div>
      <div>
        <dt><%= icon "phone", class: "icon-muted" %><span><%= t(".phone") %></span></dt>
        <dd><%= @employee.phone.presence || t(".empty_value") %></dd>
      </div>
      <div>
        <dt><%= icon "tag", class: "icon-muted" %><span><%= t(".tags") %></span></dt>
        <dd><%= @employee.tags.any? ? @employee.tags.map(&:name).join(", ") : t(".empty_value") %></dd>
      </div>
    </dl>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <h2 class="panel-title"><%= icon "lock" %><span><%= t(".access") %></span></h2>
    </div>

    <% if @employee.errors.any? %>
      <div class="error-summary">
        <strong><%= t(".error_title") %></strong>
        <ul>
          <% @employee.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: account_path, method: :patch, class: "stacked-form compact-form" do |form| %>
      <div class="field">
        <%= form.label :email, t(".email") %>
        <%= form.email_field :email, value: @employee.email, autocomplete: "email" %>
      </div>
      <div class="field">
        <%= form.label :phone, t(".phone") %>
        <%= form.telephone_field :phone, value: @employee.phone, autocomplete: "tel" %>
      </div>
      <div class="field">
        <%= form.label :current_password, t(".current_password") %>
        <%= form.password_field :current_password, autocomplete: "current-password" %>
      </div>
      <div class="field">
        <%= form.label :password, t(".new_password") %>
        <%= form.password_field :password, autocomplete: "new-password" %>
      </div>
      <div class="field">
        <%= form.label :password_confirmation, t(".password_confirmation") %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>
      <%= button_tag type: :submit, class: "button button-primary" do %>
        <%= icon "save" %>
        <span><%= t(".save") %></span>
      <% end %>
    <% end %>
  </section>
</div>
