<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-pwa="admin">
  <head>
    <%= render "layouts/head", admin: true, manifest: false, theme_color: "#f5f5f5", stylesheets: %w[application admin brand] %>
  </head>

  <body class="admin-auth-shell auth-shell">
    <main class="auth-main">
      <%= yield %>
    </main>

    <footer class="admin-auth-footer">
      <%= link_to t("admin.sessions.footer.project"), "https://github.com/royalmo/fitxa-cae.git" %>
      <%= t("admin.sessions.footer.version", version: app_version) %> —
      <%= t("admin.sessions.footer.developed_by") %>
      <%= link_to t("admin.sessions.footer.developer"), "https://ericroy.net" %>.
    </footer>
  </body>
</html>
