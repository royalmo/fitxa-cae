<% content_for :title, t(".title") %>

<section class="admin-page-heading split-intro">
  <div>
    <h1><%= t(".heading") %></h1>
    <p><%= t(".subtitle") %></p>
  </div>
  <div class="action-row">
    <%= link_to t("shared.download_csv"), "#", class: "button button-secondary" %>
    <%= link_to t("shared.download_pdf"), "#", class: "button button-primary" %>
  </div>
</section>

<section class="panel">
  <%= form_with url: admin_reports_path, method: :get, class: "filter-bar" do |form| %>
    <div class="field">
      <%= form.label :month, t(".month"), class: "sr-only" %>
      <%= form.month_field :month, value: "2026-06" %>
    </div>
    <div class="field">
      <%= form.label :employee, t(".employee"), class: "sr-only" %>
      <%= form.select :employee, [[t(".all_employees"), ""], ["Laia Ferrer", "12"], ["Nil Serra", "18"], ["Jana Soler", "21"]] %>
    </div>
    <%= form.submit t("shared.filter"), class: "button button-secondary" %>
  <% end %>
</section>

<section class="panel flush-panel">
  <table>
    <thead>
      <tr>
        <th><%= t(".employee") %></th>
        <th><%= t(".regular") %></th>
        <th><%= t(".corrections") %></th>
        <th><%= t(".incidents") %></th>
        <th><%= t(".balance") %></th>
      </tr>
    </thead>
    <tbody>
      <% @report_rows.each do |row| %>
        <tr>
          <td><strong><%= row[:employee] %></strong></td>
          <td><%= row[:regular] %></td>
          <td><%= row[:corrections] %></td>
          <td><%= row[:incidents] %></td>
          <td><%= row[:balance] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
