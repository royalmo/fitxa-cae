<!DOCTYPE html>
<% employee = current_employee || @employee %>
<% employee_theme_setting = employee_theme_preference(employee) %>
<% employee_theme_attribute = employee_theme_setting.in?(%w[light dark]) ? %( data-theme="#{employee_theme_setting}") : "" %>
<html lang="<%= I18n.locale %>"
  data-pwa="employee"
  data-employee-signed-in="<%= employee_signed_in? %>"
  data-employee-theme-preference="<%= employee_theme_setting %>"
  data-theme-preference="<%= employee_theme_setting %>"<%= raw employee_theme_attribute %>>
  <head>
    <%= render "layouts/head",
      manifest: true,
      theme_color: ApplicationHelper::EMPLOYEE_LIGHT_THEME_COLOR,
      color_scheme: "light dark",
      employee_theme: {
        preference: employee_theme_setting,
        signed_in: employee_signed_in?
      } %>
  </head>

  <body class="employee-shell"
    data-controller="employee-theme submit-feedback"
    data-employee-theme-preference-value="<%= employee_theme_setting %>"
    data-employee-theme-signed-in-value="<%= employee_signed_in? %>">
    <% full_employee_name = employee_display_name(employee) %>

    <header class="employee-topbar">
      <div class="employee-topbar-inner">
        <%= render "layouts/brand_mark", path: root_path %>

        <div class="employee-topbar-actions">
          <%= link_to account_path, class: "employee-chip", title: full_employee_name do %>
            <span><%= full_employee_name %></span>
          <% end %>

          <% if employee_signed_in? %>
            <% if current_employee.manager.present? %>
              <%= link_to admin_root_path, class: "employee-admin-button", title: t("employee.nav.admin"), aria: { label: t("employee.nav.admin") } do %>
                <%= icon "hammer" %>
              <% end %>
            <% end %>
            <%= button_to logout_path, method: :delete, form_class: "topbar-form", class: "employee-logout-button", title: t("employee.nav.logout"), aria: { label: t("employee.nav.logout") } do %>
              <%= icon "log-out", title: t("employee.nav.logout") %>
            <% end %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="<%= class_names("employee-main", content_for(:main_class)) %>">
      <%= yield %>
    </main>

    <nav class="employee-nav" aria-label="<%= t("employee.nav.label") %>">
      <%= link_to root_path, class: nav_item_class(root_path) do %>
        <%= icon "home" %>
        <span><%= t("employee.nav.today") %></span>
      <% end %>
      <%= link_to clockings_path, class: nav_item_class(clockings_path) do %>
        <%= icon "history" %>
        <span><%= t("employee.nav.clockings") %></span>
      <% end %>
      <%= link_to corrections_path, class: nav_item_class(corrections_path) do %>
        <%= icon "square-pen" %>
        <span><%= t("employee.nav.corrections") %></span>
      <% end %>
      <%= link_to account_path, class: nav_item_class(account_path) do %>
        <%= icon "user" %>
        <span><%= t("employee.nav.account") %></span>
      <% end %>
    </nav>
  </body>
</html>
