<% content_for :title, t(".title") %>

<section class="admin-page-heading split-intro">
  <h1 class="admin-page-title"><%= icon "upload", class: "admin-page-title-icon" %><span><%= t(".heading") %></span></h1>
</section>

<section class="panel">
  <%= form_with url: admin_import_path, class: "stacked-form admin-form" do |form| %>
    <div class="drop-zone">
      <%= form.label :file, t(".file") %>
      <%= form.file_field :file, accept: ".csv" %>
      <p><%= t(".columns") %></p>
    </div>

    <div class="form-actions">
      <%= link_to admin_employees_path, class: "button button-secondary" do %>
        <%= icon "x" %>
        <span><%= t("shared.cancel") %></span>
      <% end %>
      <%= button_tag type: :submit, class: "button button-primary", data: { submitting_label: t("shared.submitting.importing") } do %>
        <%= icon "upload" %>
        <span><%= t(".submit") %></span>
      <% end %>
    </div>
  <% end %>
</section>
