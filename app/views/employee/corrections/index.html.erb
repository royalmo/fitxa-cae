<% content_for :title, t(".title") %>

<section class="page-intro split-intro">
  <div>
    <h1 class="page-title"><%= icon "square-pen", class: "icon-large" %><span><%= t(".heading") %></span></h1>
    <p><%= t(".intro") %></p>
  </div>
  <%= link_to new_correction_path, class: "button button-primary" do %>
    <%= icon "square-pen" %>
    <span><%= t(".new_request") %></span>
  <% end %>
</section>

<section class="panel">
  <% if @corrections.any? %>
    <div class="request-list">
      <% @corrections.each do |correction| %>
        <article class="request-row">
          <div class="request-content">
            <%= icon "square-pen", class: "icon-muted" %>
            <div>
              <span class="muted"><%= l(correction.day, format: :long) %></span>
              <strong><%= correction_title(correction) %></strong>
              <span><%= correction_requested_text(correction) %></span>
            </div>
          </div>
          <div class="request-meta">
            <span class="<%= badge_class(correction.status) %>">
              <%= status_text(correction.status) %>
            </span>
            <small>
              <%= correction_answered_at(correction) ? l(correction_answered_at(correction), format: :short) : t(".unanswered") %>
            </small>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <%= icon "square-pen", class: "icon-muted" %>
      <p><%= t(".empty") %></p>
    </div>
  <% end %>
</section>
