<% content_for :title, t(".title") %>

<section class="auth-card auth-card-narrow employee-auth-card">
  <header class="auth-header">
    <%= render "layouts/brand_mark", path: login_path %>
    <h1><%= t(".heading") %></h1>
    <% if @masked_destination.present? %>
      <p><%= t(".sent_to", destination: @masked_destination) %></p>
    <% end %>
  </header>

  <section class="auth-panel">
    <% flash.each do |type, message| %>
      <div class="flash flash-<%= type %>"><%= message %></div>
    <% end %>

    <%= form_with url: verify_login_code_path, method: :post, class: "auth-form" do |form| %>
      <div class="field">
        <%= form.label :code, t(".code") %>
        <%= form.text_field :code, inputmode: "numeric", autocomplete: "one-time-code", required: true, maxlength: 6 %>
      </div>

      <%= form.submit t(".submit") %>
    <% end %>

    <%= link_to t(".restart"), login_path, class: "button button-secondary auth-secondary-action" %>
  </section>
</section>
