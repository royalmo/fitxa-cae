<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-pwa="admin" data-theme-preference="light" data-theme="light">
  <head>
    <%= render "layouts/head", admin: true, manifest: false, theme_color: "#f5f5f5", stylesheets: %w[application admin brand], javascript_assets: %w[admin] %>
  </head>

  <body class="admin-shell"
    data-controller="admin-theme submit-feedback admin-sidebar"
    data-admin-sidebar-open-class="is-admin-sidebar-open">
    <% manager_name = manager_display_name(@manager) %>

    <button type="button"
      class="admin-sidebar-backdrop"
      aria-label="<%= t("admin.nav.close_menu") %>"
      data-action="admin-sidebar#close"></button>

    <aside id="admin-sidebar" class="admin-sidebar" data-admin-sidebar-target="sidebar">
      <div class="admin-sidebar-header">
        <%= render "layouts/brand_mark", path: admin_root_path, class: "admin-brand", badge: t("admin.nav.admin_badge") %>
        <button type="button"
          class="icon-button admin-sidebar-close"
          title="<%= t("admin.nav.close_menu") %>"
          aria-label="<%= t("admin.nav.close_menu") %>"
          data-action="admin-sidebar#close">
          <%= icon "x" %>
        </button>
      </div>

      <nav class="admin-nav" aria-label="<%= t("admin.nav.label") %>" data-action="click->admin-sidebar#close">
        <% [
          [admin_root_path, "layout-dashboard", t("admin.nav.dashboard"), true],
          [admin_employees_path, "users", t("admin.nav.employees"), false],
          [admin_corrections_path, "square-pen", t("admin.nav.corrections"), false],
          [admin_reports_path, "chart-column", t("admin.nav.reports"), false]
        ].each do |path, icon_name, label, exact| %>
          <%= link_to path, class: nav_item_class(path, exact: exact) do %>
            <%= icon icon_name %>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </nav>
    </aside>

    <div class="admin-workspace">
      <header class="admin-header">
        <div class="admin-header-main">
          <button type="button"
            class="icon-button admin-sidebar-toggle"
            aria-controls="admin-sidebar"
            aria-expanded="false"
            title="<%= t("admin.nav.open_menu") %>"
            aria-label="<%= t("admin.nav.open_menu") %>"
            data-admin-sidebar-target="button"
            data-action="admin-sidebar#toggle">
            <%= icon "menu" %>
          </button>
          <div class="admin-header-copy">
            <p class="eyebrow"><%= t("admin.area") %></p>
            <strong><%= manager_name %></strong>
          </div>
        </div>
        <div class="admin-profile">
          <span><%= t("admin.role") %></span>
          <%= button_to admin_logout_path, method: :delete, form_class: "topbar-form", class: "icon-button", title: t("admin.nav.logout"), aria: { label: t("admin.nav.logout") } do %>
            <%= icon "log-out" %>
          <% end %>
        </div>
      </header>

      <% flash.each do |type, message| %>
        <div class="flash flash-<%= type %>"><%= message %></div>
      <% end %>

      <main class="admin-main">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
