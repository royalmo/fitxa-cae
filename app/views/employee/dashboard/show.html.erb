<% content_for :title, t(".title") %>

<section class="employee-hero">
  <div>
    <p class="eyebrow"><%= t(".date") %> · <%= l(Date.current, format: :weekday_day_month) %></p>
    <h1><%= t(".hello", name: @employee[:first_name]) %></h1>
  </div>
</section>

<section class="clock-card">
  <p class="clock-label">
    <%= icon "clock", class: "icon-inverse" %>
    <span><%= t(".clocked_in_since") %></span>
  </p>
  <time class="clock-time" datetime="<%= @employee[:clocked_in_at].iso8601 %>">
    <%= l(@employee[:clocked_in_at], format: :hour_minute) %>
  </time>

  <% if @employee[:clocked_in] %>
    <%= button_to clock_out_path, method: :post, form_class: "clock-action-form", class: "primary-clock danger" do %>
      <%= icon "log-out", class: "icon-large" %>
      <span><%= t(".clock_out") %></span>
    <% end %>
  <% else %>
    <%= button_to clock_in_path, method: :post, form_class: "clock-action-form", class: "primary-clock" do %>
      <%= icon "log-in", class: "icon-large" %>
      <span><%= t(".clock_in") %></span>
    <% end %>
  <% end %>

</section>

<div class="employee-grid">
  <section class="panel">
    <div class="panel-heading">
      <h2 class="panel-title"><%= icon "calendar-days" %><span><%= t(".week_title") %></span></h2>
    </div>

    <dl class="metric-list">
      <div>
        <dt><%= t(".worked") %></dt>
        <dd><%= @week_summary[:worked] %></dd>
      </div>
      <div>
        <dt><%= t(".days") %></dt>
        <dd><%= t(".days_count", count: @week_summary[:days]) %></dd>
      </div>
      <div>
        <dt><%= t(".corrections") %></dt>
        <dd><%= @week_summary[:corrections] %></dd>
      </div>
    </dl>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <h2 class="panel-title"><%= icon "list-checks" %><span><%= t(".today_clockings") %></span></h2>
    </div>

    <ol class="timeline">
      <% @today_clockings.each do |clocking| %>
        <li>
          <span class="timeline-icon"><%= icon clocking_icon_name(clocking[:kind]) %></span>
          <time><%= clocking[:time] %></time>
          <div>
            <strong><%= clocking_kind_text(clocking[:kind]) %></strong>
            <span><%= clocking[:place] %> · <%= source_text(clocking[:source]) %></span>
          </div>
        </li>
      <% end %>
    </ol>
  </section>
</div>

<section class="panel">
  <div class="panel-heading">
    <h2 class="panel-title"><%= icon "square-pen" %><span><%= t(".correction_title") %></span></h2>
    <%= link_to new_correction_path, class: "text-button" do %>
      <%= icon "square-pen" %>
      <span><%= t(".request_correction") %></span>
    <% end %>
  </div>

  <% if @pending_correction %>
    <div class="request-row">
      <div class="request-content">
        <%= icon "square-pen", class: "icon-muted" %>
        <div>
          <strong><%= @pending_correction[:title] %></strong>
          <span><%= @pending_correction[:requested] %></span>
        </div>
      </div>
      <span class="<%= badge_class(@pending_correction[:status]) %>">
        <%= status_text(@pending_correction[:status]) %>
      </span>
    </div>
  <% else %>
    <p class="muted"><%= t(".correction_empty") %></p>
  <% end %>
</section>
