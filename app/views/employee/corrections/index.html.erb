<% content_for :title, t(".title") %>

<section class="page-intro split-intro">
  <div>
    <h1 class="page-title"><%= icon "square-pen", class: "icon-large" %><span><%= t(".heading") %></span></h1>
    <p><%= t(".intro") %></p>
  </div>
  <%= link_to new_correction_path, class: "button button-primary" do %>
    <%= icon "square-pen" %>
    <span><%= t(".new_request") %></span>
  <% end %>
</section>

<section class="panel">
  <div class="request-list">
    <% @corrections.each do |correction| %>
      <article class="request-row">
        <div class="request-content">
          <%= icon "square-pen", class: "icon-muted" %>
          <div>
            <span class="muted"><%= l(correction[:date], format: :long) %></span>
            <strong><%= correction[:title] %></strong>
            <span><%= correction[:requested] %></span>
          </div>
        </div>
        <div class="request-meta">
          <span class="<%= badge_class(correction[:status]) %>">
            <%= status_text(correction[:status]) %>
          </span>
          <small>
            <%= correction[:answered_at] ? l(correction[:answered_at], format: :short) : t(".unanswered") %>
          </small>
        </div>
      </article>
    <% end %>
  </div>
</section>
