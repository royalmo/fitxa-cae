<% content_for :title, t(".title") %>
<% correction_month_options = (1..12).map do |month_number|
  month_date = Date.new(@selected_month.year, month_number, 1)
  disabled = month_date < @min_correction_month || month_date > @max_correction_month
  [l(month_date, format: "%B"), month_number, { disabled: disabled }]
end %>
<% correction_year_values = ((@min_correction_month.year..@max_correction_month.year).to_a + [@selected_month.year]).uniq.sort %>
<% correction_year_options = correction_year_values.map do |year|
  [year, year, { disabled: year < @min_correction_month.year || year > @max_correction_month.year }]
end %>
<% selected_correction_month_unavailable = @selected_month < @min_correction_month || @selected_month > @max_correction_month %>
<% selected_correction_year_unavailable = @selected_month.year < @min_correction_month.year || @selected_month.year > @max_correction_month.year %>

<section class="page-intro split-intro corrections-intro">
  <div>
    <h1 class="page-title"><%= icon "square-pen", class: "icon-large" %><span><%= t(".heading") %></span></h1>
  </div>
  <%= link_to new_correction_path, class: "button button-primary correction-new-link" do %>
    <%= icon "square-pen" %>
    <span><%= t(".new_request") %></span>
  <% end %>
</section>

<%= render "layouts/flash_messages", class: "employee-page-flash" %>

<div data-controller="list-loading">
  <%= form_with url: corrections_path, method: :get, class: "corrections-filter-form" do |form| %>
    <fieldset class="corrections-filter-panel">
      <legend class="sr-only"><%= t(".filters") %></legend>
      <div class="corrections-filter-header">
        <p class="corrections-filter-heading"><%= t(".filters") %>:</p>
        <% if @corrections_count.positive? %>
          <p class="corrections-result-count" data-list-loading-target="results">
            <%= t(".showing_count",
              from: @corrections_range_start,
              to: @corrections_range_end,
              count: @corrections_count) %>
          </p>
        <% end %>
      </div>
      <hr class="corrections-filter-divider">
      <fieldset class="corrections-status-filter">
        <legend class="sr-only"><%= t(".status") %></legend>
        <span class="corrections-filter-label"><%= t(".status") %>:</span>
        <div class="corrections-status-options">
          <% [[t(".all_statuses"), nil]].
            concat(@filterable_statuses.map { |status| [correction_status_radio_label(status), status] }).
            each do |label, status| %>
            <% radio_id = "corrections_status_#{status.presence || "all"}" %>
            <label class="corrections-status-option" for="<%= radio_id %>">
              <%= radio_button_tag :status,
                status.to_s,
                @selected_status == status,
                id: radio_id,
                autocomplete: "off",
                data: { action: "change->list-loading#filter" } %>
              <% if status.present? %>
                <%= icon correction_status_icon_name(status), class: "corrections-status-option-icon" %>
              <% end %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </fieldset>

      <div class="corrections-month-filter">
        <span class="corrections-filter-label"><%= t(".month") %>:</span>
        <%= label_tag "corrections_month", t(".month"), class: "sr-only" %>
        <%= hidden_field_tag :month, @selected_month.month if selected_correction_month_unavailable %>
        <%= select_tag :month,
          options_for_select(correction_month_options, @selected_month.month),
          id: "corrections_month",
          data: { action: "change->list-loading#filter" } %>

        <span class="corrections-month-join"><%= t(".month_year_join") %></span>

        <%= label_tag "corrections_year", t(".year"), class: "sr-only" %>
        <%= hidden_field_tag :year, @selected_month.year if selected_correction_year_unavailable %>
        <%= select_tag :year,
          options_for_select(correction_year_options, @selected_month.year),
          id: "corrections_year",
          data: { action: "change->list-loading#filter" } %>
      </div>
    </fieldset>

    <noscript>
      <%= form.submit t("shared.filter"), class: "button button-secondary", data: { submitting_label: t("shared.submitting.filtering") } %>
    </noscript>
  <% end %>

  <div data-list-loading-target="results">
    <% if @corrections.any? %>
      <section class="corrections-list" aria-label="<%= t(".heading") %>">
        <% @corrections.each do |correction| %>
          <%= link_to employee_correction_row_path(correction),
            class: class_names("correction-row", "is-#{correction.status}"),
            aria: { label: t(".open_correction", date: l(correction.day, format: :weekday_day_month)) } do %>
            <div class="correction-status">
              <%= icon correction_status_icon_name(correction.status),
                title: status_text(correction.status),
                class: class_names("correction-status-icon", "is-#{correction.status}") %>
            </div>
            <div class="correction-content">
              <strong class="correction-day-title">
                <time datetime="<%= correction.day.iso8601 %>"><%= l(correction.day, format: :weekday_day_month) %></time>
                <% if correction_created_by_human_resources?(correction) %>
                  <% human_resources_created_tooltip = t("employee.corrections.human_resources_created_tooltip") %>
                  <span class="correction-human-resources-marker"
                    aria-label="<%= human_resources_created_tooltip %>"
                    data-tooltip="<%= human_resources_created_tooltip %>">
                    <%= icon "hammer", class: "correction-human-resources-icon" %>
                  </span>
                <% end %>
              </strong>
              <% change_items = correction_change_items(correction, @correction_invalidated_swipes_by_id) %>
              <% if change_items.any? %>
                <div class="correction-change-summary" aria-label="<%= change_items.map { |item| correction_change_item_label(item) }.join(" · ") %>">
                  <% change_items.each_with_index do |item, index| %>
                    <% if index.positive? %>
                      <span class="correction-change-separator" aria-hidden="true">·</span>
                    <% end %>
                    <span class="correction-change-item is-<%= item[:type] %>">
                      <%= icon correction_change_icon_name(item),
                        title: correction_change_icon_title(item),
                        class: "correction-change-icon" %>
                      <span><%= item[:time] %></span>
                    </span>
                  <% end %>
                </div>
              <% else %>
                <p><%= t("employee.corrections.summary.no_details") %></p>
              <% end %>
            </div>
            <div class="correction-result">
              <span class="correction-row-action">
                <%= icon correction.pending? ? "pencil" : "eye",
                  title: correction.pending? ? t("shared.edit") : t("shared.view"),
                  class: "correction-row-action-icon" %>
              </span>
            </div>
          <% end %>
        <% end %>
      </section>

      <% if @total_pages > 1 %>
        <% correction_pagination_params = {
          status: @selected_status,
          month: @selected_month.month,
          year: @selected_month.year
        }.compact %>

        <nav class="corrections-pagination" aria-label="<%= t(".pagination") %>">
          <% if @previous_page %>
            <%= link_to t(".previous_page"), corrections_path(correction_pagination_params.merge(page: @previous_page)), class: "corrections-page-link", data: { action: "click->list-loading#navigate" } %>
          <% else %>
            <span class="corrections-page-link is-disabled"><%= t(".previous_page") %></span>
          <% end %>

          <span class="corrections-page-status"><%= t(".page_status", page: @page, total_pages: @total_pages) %></span>

          <% if @next_page %>
            <%= link_to t(".next_page"), corrections_path(correction_pagination_params.merge(page: @next_page)), class: "corrections-page-link", data: { action: "click->list-loading#navigate" } %>
          <% else %>
            <span class="corrections-page-link is-disabled"><%= t(".next_page") %></span>
          <% end %>
        </nav>
      <% end %>
    <% else %>
      <div class="empty-state corrections-empty-state">
        <%= icon "square-pen", class: "empty-state-icon" %>
        <p><%= correction_empty_message(@selected_month, @selected_status) %></p>
      </div>
    <% end %>
  </div>

  <div class="list-loading-state" data-list-loading-target="loading" role="status" aria-live="polite" hidden>
    <span class="submit-spinner list-loading-spinner" aria-hidden="true"></span>
    <p><%= t(".loading") %></p>
  </div>
</div>
