<% content_for :title, t(".title") %>

<section class="admin-page-heading">
  <div>
    <h1><%= t(".heading") %></h1>
    <p><%= t(".subtitle") %></p>
  </div>
</section>

<section class="stat-grid">
  <% @stats.each do |stat| %>
    <article class="stat-card">
      <span><%= stat[:label] %></span>
      <strong><%= stat[:value] %></strong>
      <small><%= stat[:detail] %></small>
    </article>
  <% end %>
</section>

<div class="admin-grid">
  <section class="panel flush-panel">
    <div class="panel-heading padded-heading">
      <h2><%= t(".live_title") %></h2>
      <%= link_to t("shared.view"), admin_employees_path, class: "text-button" %>
    </div>

    <table>
      <thead>
        <tr>
          <th><%= t(".employee") %></th>
          <th><%= t(".tags") %></th>
          <th><%= t(".last_clocking") %></th>
        </tr>
      </thead>
      <tbody>
        <% @recent_swipes.each do |swipe| %>
          <tr>
            <td>
              <div class="person-cell">
                <span class="avatar avatar-small"><%= initials(employee_display_name(swipe.employee)) %></span>
                <span><%= employee_display_name(swipe.employee) %></span>
              </div>
            </td>
            <td><%= swipe.employee.tags.any? ? swipe.employee.tags.map(&:name).join(", ") : t(".no_tags") %></td>
            <td><%= clocking_kind_text(swipe.kind) %> · <%= l(swipe.swipe_at, format: :short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @recent_swipes.empty? %>
      <div class="empty-state">
        <p><%= t(".no_recent_swipes") %></p>
      </div>
    <% end %>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <h2><%= t(".corrections_title") %></h2>
      <%= link_to t("shared.view"), admin_corrections_path, class: "text-button" %>
    </div>

    <div class="request-list compact-list">
      <% @pending_corrections.each do |correction| %>
        <article class="request-row">
          <div>
            <strong><%= employee_display_name(correction.employee) %></strong>
            <span><%= correction_requested_text(correction) %></span>
          </div>
          <small><%= l(correction.created_at, format: :short) %></small>
        </article>
      <% end %>
    </div>

    <% if @pending_corrections.empty? %>
      <p class="muted"><%= t(".no_pending_corrections") %></p>
    <% end %>
  </section>
</div>
