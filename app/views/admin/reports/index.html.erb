<% content_for :title, t(".title") %>

<section class="admin-page-heading split-intro">
  <div>
    <h1><%= t(".heading") %></h1>
    <p><%= t(".subtitle") %></p>
  </div>
  <div class="action-row">
    <%= link_to t("shared.download_csv"), "#", class: "button button-secondary" %>
    <%= link_to t("shared.download_pdf"), "#", class: "button button-primary" %>
  </div>
</section>

<section class="panel">
  <%= form_with url: admin_reports_path, method: :get, class: "filter-bar" do |form| %>
    <div class="field">
      <%= form.label :month, t(".month"), class: "sr-only" %>
      <%= form.month_field :month, value: @month.strftime("%Y-%m") %>
    </div>
    <div class="field">
      <%= form.label :employee_id, t(".employee"), class: "sr-only" %>
      <%= form.select :employee_id, [[t(".all_employees"), ""]] + @employees.map { |employee| [employee_display_name(employee), employee.id] }, selected: @selected_employee_id %>
    </div>
    <%= form.submit t("shared.filter"), class: "button button-secondary", data: { submitting_label: t("shared.submitting.filtering") } %>
  <% end %>
</section>

<section class="panel flush-panel">
  <table>
    <thead>
      <tr>
        <th><%= t(".employee") %></th>
        <th><%= t(".hours") %></th>
        <th><%= t(".days") %></th>
        <th><%= t(".corrections") %></th>
      </tr>
    </thead>
    <tbody>
      <% @report_rows.each do |row| %>
        <tr>
          <td><strong><%= employee_display_name(row[:employee]) %></strong></td>
          <td><%= duration_text(row[:worked_seconds]) %></td>
          <td><%= row[:days] %></td>
          <td><%= row[:corrections] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @report_rows.empty? %>
    <div class="empty-state">
      <p><%= t(".empty") %></p>
    </div>
  <% end %>
</section>
