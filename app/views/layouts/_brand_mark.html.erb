<%= link_to local_assigns.fetch(:path), class: class_names("brand-mark", local_assigns[:class]), aria: { label: t("app.name") } do %>
  <span class="brand-wordmark">
    <span class="brand-fitxa">Fitxa</span>
    <% if local_assigns[:badge].present? %>
      <span class="brand-badge"><%= local_assigns[:badge] %></span>
    <% end %>
  </span>
  <%= image_tag "cae_logo_trimmed.png", alt: "CAE", class: "brand-logo" %>
<% end %>
