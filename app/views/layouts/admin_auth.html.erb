<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-pwa="admin" data-theme-preference="light" data-theme="light">
  <head>
    <%= render "layouts/head", admin: true, manifest: false, theme_color: "#f5f5f5", stylesheets: %w[application admin brand] %>
  </head>

  <body class="admin-auth-shell auth-shell" data-controller="admin-theme submit-feedback">
    <main class="auth-main">
      <%= yield %>
    </main>

    <%= render "layouts/auth_footer",
      class: "admin-auth-footer",
      access_label: t("shared.auth_footer.employee_access"),
      access_path: root_path %>
  </body>
</html>
