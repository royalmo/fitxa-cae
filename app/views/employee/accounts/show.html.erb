<% content_for :title, t(".title") %>
<% password_error_messages = @account_error_context.to_s == "password" ? @employee.errors.full_messages : [] %>
<% contact_error_messages = @account_error_context.to_s == "contact" ? @employee.errors.full_messages : [] %>
<% password_panel_open = @password_panel_open || password_error_messages.any? || params.values_at(:password, :password_confirmation).any?(&:present?) %>
<% account_theme_options = [
  [ "light", "sun", t("employee.themes.light") ],
  [ "dark", "moon", t("employee.themes.dark") ],
  [ "system", "monitor", t("employee.themes.system") ]
] %>

<section class="page-intro">
  <div>
    <h1 class="page-title"><%= icon "user", class: "icon-large" %><span><%= t(".heading") %></span></h1>
  </div>
</section>

<%= render "layouts/flash_messages",
  class: "employee-page-flash",
  except: %i[hr_contact_notice hr_contact_alert] %>

<div class="account-layout">
  <section class="account-section">
    <div class="stacked-form">
      <div class="field">
        <%= label_tag :employee_name, t(".name") %>
        <%= text_field_tag :employee_name, employee_display_name(@employee), readonly: true %>
      </div>
      <div class="field">
        <%= label_tag :employee_national_id, t(".national_id") %>
        <%= text_field_tag :employee_national_id, @employee.national_id, readonly: true %>
      </div>
    </div>
  </section>

  <section class="account-section">
    <%= render "layouts/error_summary", messages: contact_error_messages, title: t(".error_title") %>

    <%= form_with url: account_contact_path,
      method: :patch,
      class: "stacked-form compact-form account-contact-form",
      data: { turbo: false },
      html: { id: "account_contact_form" } do |form| %>
      <div class="field">
        <%= form.label :email, t(".email") %>
        <%= form.email_field :email, value: @employee.email, autocomplete: "email" %>
      </div>
      <div class="field">
        <%= form.label :phone, t(".phone") %>
        <%= form.telephone_field :phone, value: @employee.phone, autocomplete: "tel" %>
      </div>
      <div class="account-theme-field">
        <span id="account_theme_label" class="account-theme-label"><%= t(".theme") %>:</span>
        <div class="account-theme-options" role="radiogroup" aria-labelledby="account_theme_label" data-action="change->employee-theme#choose">
          <% account_theme_options.each do |preference, icon_name, label| %>
            <% radio_id = "account_theme_#{preference}" %>
            <label class="corrections-status-option account-theme-option" for="<%= radio_id %>">
              <%= radio_button_tag :theme_preference,
                preference,
                @employee.theme_preference == preference,
                id: radio_id,
                autocomplete: "off" %>
              <%= icon icon_name, class: "corrections-status-option-icon account-theme-option-icon" %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="account-actions-row">
      <details class="account-password-panel" <%= "open" if password_panel_open %>>
        <summary class="account-action-button account-password-summary">
          <span><%= t(".change_password") %></span>
          <%= icon "chevron-down", class: "account-summary-icon account-summary-icon-down" %>
          <%= icon "chevron-up", class: "account-summary-icon account-summary-icon-up" %>
        </summary>

        <%= render "layouts/error_summary", messages: password_error_messages, title: t(".error_title") %>

        <%= form_with url: account_password_path, method: :patch, class: "stacked-form compact-form account-password-form" do |form| %>
          <div class="field">
            <%= form.label :password, t(".new_password") %>
            <%= form.password_field :password, autocomplete: "new-password" %>
          </div>
          <div class="field">
            <%= form.label :password_confirmation, t(".password_confirmation") %>
            <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
          </div>

          <div class="account-actions">
            <%= button_tag type: :submit, class: "button account-action-button account-primary-button", data: { submitting_label: t("shared.submitting.changing") } do %>
              <span><%= t(".change_password_submit") %></span>
            <% end %>
          </div>
        <% end %>
      </details>

      <%= button_tag type: :submit, form: "account_contact_form", class: "button account-action-button account-primary-button account-save-button", data: { submitting_label: t("shared.submitting.saving") } do %>
        <span><%= t(".save") %></span>
      <% end %>
    </div>
  </section>
</div>

<hr class="account-divider">

<section class="account-hr-contact" id="human_resources_contact">
  <h2><%= t(".human_resources_contact") %></h2>

  <%= render "layouts/flash_messages",
    class: "employee-page-flash account-hr-flash",
    only: %i[hr_contact_notice hr_contact_alert] %>

  <%= form_with url: account_human_resources_contact_path,
    method: :post,
    class: "stacked-form compact-form account-hr-contact-form",
    html: { autocomplete: "off" } do |form| %>
    <div class="field">
      <%= form.label :subject, t(".human_resources_subject"), class: "sr-only" %>
      <%= form.text_field :subject,
        value: @hr_contact_form&.fetch(:subject, nil),
        placeholder: t(".human_resources_subject"),
        autocomplete: "off",
        required: true %>
    </div>

    <div class="field">
      <%= form.label :message, t(".human_resources_message"), class: "sr-only" %>
      <%= form.text_area :message,
        value: @hr_contact_form&.fetch(:message, nil),
        placeholder: t(".human_resources_message"),
        rows: 4,
        autocomplete: "off",
        required: true %>
    </div>

    <div class="account-actions">
      <%= button_tag type: :submit, class: "button account-action-button account-primary-button", data: { submitting_label: t("shared.submitting.sending") } do %>
        <span><%= t(".human_resources_submit") %></span>
      <% end %>
    </div>
  <% end %>
</section>
