<% content_for :title, t(".title") %>

<section class="page-intro">
  <div>
    <h1 class="page-title"><%= icon "user", class: "icon-large" %><span><%= t(".heading") %></span></h1>
    <p><%= t(".intro") %></p>
  </div>
</section>

<div class="employee-grid">
  <section class="panel">
    <div class="panel-heading">
      <h2 class="panel-title"><%= icon "user" %><span><%= t(".personal_data") %></span></h2>
    </div>

    <dl class="detail-list">
      <div>
        <dt><%= icon "user", class: "icon-muted" %><span><%= t(".name") %></span></dt>
        <dd><%= @employee[:name] %></dd>
      </div>
      <div>
        <dt><%= icon "mail", class: "icon-muted" %><span><%= t(".email") %></span></dt>
        <dd><%= @employee[:email] %></dd>
      </div>
      <div>
        <dt><%= icon "map-pin", class: "icon-muted" %><span><%= t(".work_center") %></span></dt>
        <dd><%= @employee[:work_center] %></dd>
      </div>
    </dl>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <h2 class="panel-title"><%= icon "lock" %><span><%= t(".access") %></span></h2>
    </div>

    <%= form_with url: account_path, method: :patch, class: "stacked-form compact-form" do |form| %>
      <div class="field">
        <%= form.label :current_password, t(".current_password") %>
        <%= form.password_field :current_password, autocomplete: "current-password" %>
      </div>
      <div class="field">
        <%= form.label :password, t(".new_password") %>
        <%= form.password_field :password, autocomplete: "new-password" %>
      </div>
      <%= button_tag type: :submit, class: "button button-primary" do %>
        <%= icon "lock" %>
        <span><%= t(".save_password") %></span>
      <% end %>
    <% end %>
  </section>
</div>
