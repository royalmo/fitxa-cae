<% content_for :title, t(".title") %>

<section class="page-intro">
  <div>
    <h1 class="page-title"><%= icon "square-pen", class: "icon-large" %><span><%= t(".heading") %></span></h1>
  </div>
</section>

<%= render "layouts/flash_messages", class: "employee-page-flash" %>

<section class="panel">
  <%= render "layouts/error_summary", errors: @correction.errors, title: t(".error_title") %>

  <%= form_with url: corrections_path, class: "stacked-form" do |form| %>
    <div class="field-row">
      <div class="field">
        <%= form.label :date, t(".date") %>
        <%= form.date_field :date,
          value: params[:date].presence || @correction.day || Date.current,
          min: @correction_date_range.begin.iso8601,
          max: @correction_date_range.end.iso8601 %>
      </div>

      <div class="field">
        <%= form.label :kind, t(".kind") %>
        <%= form.select :kind, [
          [t(".kind_missing_entry"), "missing_entry"],
          [t(".kind_missing_exit"), "missing_exit"],
          [t(".kind_wrong_entry"), "wrong_entry"],
          [t(".kind_wrong_exit"), "wrong_exit"]
        ], selected: params[:kind] %>
      </div>
    </div>

    <div class="field">
      <%= form.label :time, t(".time") %>
      <%= form.time_field :time, value: params[:time].presence || "08:00" %>
    </div>

    <div class="field">
      <%= form.label :note, t(".note") %>
      <%= form.text_area :note, rows: 5, value: params[:note].presence || @correction.requester_comments, placeholder: t(".note_placeholder") %>
    </div>

    <fieldset class="choice-list">
      <legend><%= t(".invalidated_swipes") %></legend>
      <% if @recent_swipes.any? %>
        <% selected_swipe_ids = Array(params[:invalidated_swipe_ids]).map(&:to_s) %>
        <% @recent_swipes.each do |swipe| %>
          <label>
            <%= check_box_tag "invalidated_swipe_ids[]", swipe.id, selected_swipe_ids.include?(swipe.id.to_s) %>
            <span>
              <%= l(swipe.swipe_at.to_date, format: :short) %> ·
              <%= l(swipe.swipe_at, format: :hour_minute) %> ·
              <%= clocking_kind_text(swipe.kind) %>
            </span>
          </label>
        <% end %>
      <% else %>
        <p class="muted"><%= t(".invalidated_swipes_empty") %></p>
      <% end %>
    </fieldset>

    <div class="form-actions">
      <%= link_to corrections_path, class: "button button-secondary" do %>
        <%= icon "x" %>
        <span><%= t("shared.cancel") %></span>
      <% end %>
      <%= button_tag type: :submit, class: "button button-primary", data: { submitting_label: t("shared.submitting.sending") } do %>
        <%= icon "send" %>
        <span><%= t(".submit") %></span>
      <% end %>
    </div>
  <% end %>
</section>
