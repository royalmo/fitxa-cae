<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-pwa="admin">
  <head>
    <%= render "layouts/head", admin: true, manifest: false, theme_color: "#f5f5f5", stylesheets: %w[application admin brand] %>
  </head>

  <body class="admin-auth-shell auth-shell">
    <% flash.each do |type, message| %>
      <div class="flash flash-<%= type %>"><%= message %></div>
    <% end %>

    <main class="auth-main">
      <%= yield %>
    </main>
  </body>
</html>
