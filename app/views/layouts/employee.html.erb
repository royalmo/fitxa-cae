<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-pwa="employee">
  <head>
    <%= render "layouts/head", manifest: true, theme_color: "#e30613" %>
  </head>

  <body class="employee-shell" data-controller="submit-feedback">
    <% employee_name = employee_display_name(current_employee || @employee) %>

    <header class="employee-topbar">
      <div class="employee-topbar-inner">
        <%= render "layouts/brand_mark", path: root_path %>

        <div class="employee-topbar-actions">
          <div class="employee-chip">
            <span><%= employee_name %></span>
          </div>

          <% if employee_signed_in? %>
            <%= button_to logout_path, method: :delete, form_class: "topbar-form", class: "employee-logout-button", title: t("employee.nav.logout"), aria: { label: t("employee.nav.logout") } do %>
              <%= icon "log-out", title: t("employee.nav.logout") %>
            <% end %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="employee-main">
      <%= yield %>
    </main>

    <nav class="employee-nav" aria-label="<%= t("employee.nav.label") %>">
      <%= link_to root_path, class: nav_item_class(root_path) do %>
        <%= icon "home" %>
        <span><%= t("employee.nav.today") %></span>
      <% end %>
      <%= link_to clockings_path, class: nav_item_class(clockings_path) do %>
        <%= icon "history" %>
        <span><%= t("employee.nav.clockings") %></span>
      <% end %>
      <%= link_to corrections_path, class: nav_item_class(corrections_path) do %>
        <%= icon "square-pen" %>
        <span><%= t("employee.nav.corrections") %></span>
      <% end %>
      <%= link_to account_path, class: nav_item_class(account_path) do %>
        <%= icon "user" %>
        <span><%= t("employee.nav.account") %></span>
      <% end %>
    </nav>
  </body>
</html>
