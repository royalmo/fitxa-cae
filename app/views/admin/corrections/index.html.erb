<% content_for :title, t(".title") %>
<% pagination_path = ->(page) { admin_corrections_path(request.query_parameters.except("page").merge(page: page)) } %>

<div class="d-flex align-items-center gap-2 mb-4">
  <%= icon "square-pen", class: "admin-page-title-icon" %>
  <h1 class="h2 mb-0"><%= t(".heading") %></h1>
</div>

<div data-controller="list-loading">
  <section class="card shadow-sm mb-3">
    <div class="card-body">
      <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <h2 class="h6 mb-0"><%= t("admin.filters.title") %></h2>
        <%= render "admin/shared/result_count",
          count: @admin_records_count,
          range_start: @admin_records_range_start,
          range_end: @admin_records_range_end %>
      </div>

      <%= form_with url: admin_corrections_path, method: :get, class: "row g-2 align-items-end" do |form| %>
        <div class="col-12 col-md-4">
          <%= form.label :status, t(".status"), class: "form-label visually-hidden" %>
          <%= form.select :status,
            [[t(".all_statuses"), ""]] + @filterable_statuses.map { |status| [status_text(status), status] },
            { selected: @selected_status },
            class: "form-select",
            data: { action: "change->list-loading#filter" } %>
        </div>
        <div class="col-12 col-md-6">
          <%= form.label :employee_id, t(".employee"), class: "form-label visually-hidden" %>
          <%= form.select :employee_id,
            [[t(".all_employees"), ""]] + @employees.map { |employee| [employee_display_name(employee), employee.id] },
            { selected: @selected_employee_id },
            class: "form-select",
            data: { action: "change->list-loading#filter" } %>
        </div>
        <div class="col-12 col-md-auto">
          <%= button_tag type: :submit, class: "btn btn-outline-secondary d-inline-flex align-items-center gap-2", data: { submitting_label: t("shared.submitting.filtering") } do %>
            <%= icon "filter" %>
            <span><%= t("shared.filter") %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <div data-list-loading-target="results">
    <section class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 admin-table">
          <thead class="table-light">
            <tr>
              <th><%= t(".employee") %></th>
              <th><%= t(".date") %></th>
              <th><%= t(".request") %></th>
              <th><%= t(".status") %></th>
              <th><%= t(".validator") %></th>
              <th><%= t(".age") %></th>
              <th class="text-end"><%= t("shared.actions") %></th>
            </tr>
          </thead>
          <tbody>
            <% @corrections.each do |correction| %>
              <tr>
                <td><strong><%= employee_display_name(correction.employee) %></strong></td>
                <td><%= l(correction.day, format: :short) %></td>
                <td>
                  <strong><%= correction_title(correction) %></strong>
                  <div class="small text-body-secondary"><%= correction_requested_text(correction) %></div>
                </td>
                <td>
                  <span class="<%= class_names(badge_class(correction.status), "admin-status-badge rounded-pill") %>">
                    <%= icon correction_status_icon_name(correction.status), class: "admin-badge-icon" %>
                    <span><%= status_text(correction.status) %></span>
                  </span>
                </td>
                <td><%= correction.validator ? manager_display_name(correction.validator) : "—" %></td>
                <td><%= l(correction.created_at, format: :short) %></td>
                <td class="text-end">
                  <% if correction.pending? %>
                    <div class="d-inline-flex gap-1 admin-table-actions">
                      <%= button_to approve_admin_correction_path(correction),
                        method: :post,
                        class: "btn btn-sm btn-outline-success admin-row-action",
                        title: t("shared.approve"),
                        aria: { label: t("shared.approve") },
                        data: { submitting_label: t("shared.submitting.approving") } do %>
                        <%= icon "check" %>
                      <% end %>
                      <%= button_to reject_admin_correction_path(correction),
                        method: :post,
                        class: "btn btn-sm btn-outline-danger admin-row-action",
                        title: t("shared.reject"),
                        aria: { label: t("shared.reject") },
                        data: { submitting_label: t("shared.submitting.rejecting") } do %>
                        <%= icon "x" %>
                      <% end %>
                    </div>
                  <% else %>
                    <span class="text-body-secondary">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @corrections.empty? %>
        <div class="card-body text-center text-body-secondary">
          <%= t(".empty") %>
        </div>
      <% end %>
    </section>

    <%= render "admin/shared/pagination",
      page: @admin_page,
      total_pages: @admin_total_pages,
      previous_page: @admin_previous_page,
      next_page: @admin_next_page,
      path: pagination_path %>
  </div>

  <%= render "admin/shared/list_loading" %>
</div>
