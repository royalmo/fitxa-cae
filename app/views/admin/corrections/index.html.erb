<% content_for :title, t(".title") %>

<section class="admin-page-heading">
  <div>
    <h1><%= t(".heading") %></h1>
    <p><%= t(".subtitle") %></p>
  </div>
</section>

<section class="panel flush-panel">
  <table>
    <thead>
      <tr>
        <th><%= t(".employee") %></th>
        <th><%= t(".date") %></th>
        <th><%= t(".request") %></th>
        <th><%= t(".status") %></th>
        <th><%= t(".validator") %></th>
        <th><%= t(".age") %></th>
        <th><%= t("shared.actions") %></th>
      </tr>
    </thead>
    <tbody>
      <% @corrections.each do |correction| %>
        <tr>
          <td><strong><%= employee_display_name(correction.employee) %></strong></td>
          <td><%= l(correction.day, format: :short) %></td>
          <td>
            <strong><%= correction_title(correction) %></strong><br>
            <span class="muted"><%= correction_requested_text(correction) %></span>
          </td>
          <td>
            <span class="<%= badge_class(correction.status) %>"><%= status_text(correction.status) %></span>
          </td>
          <td><%= correction.validator ? manager_display_name(correction.validator) : "—" %></td>
          <td><%= l(correction.created_at, format: :short) %></td>
          <td>
            <% if correction.pending? %>
              <div class="inline-actions">
                <%= button_to t("shared.approve"), approve_admin_correction_path(correction), method: :post, class: "mini-button" %>
                <%= button_to t("shared.reject"), reject_admin_correction_path(correction), method: :post, class: "mini-button muted-button" %>
              </div>
            <% else %>
              <span class="muted"><%= t("shared.view") %></span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @corrections.empty? %>
    <div class="empty-state">
      <p><%= t(".empty") %></p>
    </div>
  <% end %>
</section>
