<% content_for :title, t(".title") %>
<% content_for :main_class, "today-main" %>

<section class="page-intro today-intro">
  <div>
    <h1 class="page-title"><span><%= t(".hello", name: @employee.first_name) %></span></h1>
    <p class="today-date">
      <time datetime="<%= @today.iso8601 %>"><%= dashboard_date_text(@today) %></time>
    </p>
  </div>
</section>

<%= render "layouts/flash_messages", class: "employee-page-flash" %>

<% punch_duration = dashboard_duration_parts(@today_worked_seconds) %>

<div class="today-layout">
  <section class="today-punch-section" aria-label="<%= t(".title") %>">
    <% if @clock_state[:clocked_in] %>
      <%= button_to clock_out_path,
        method: :post,
        form_class: "clock-action-form today-punch-action-form",
        class: "today-punch-button is-active",
        data: {
          controller: "punch-timer",
          punch_timer_base_seconds_value: @today_worked_seconds,
          punch_timer_started_at_value: @clock_state[:clocked_in_at]&.iso8601,
          submitting_label: t("shared.submitting.sending")
        }.compact do %>
        <span class="today-punch-action-row">
          <%= icon "log-out" %>
          <span class="today-punch-label"><%= t(".clock_out") %></span>
        </span>
        <span class="today-punch-duration">
          <span class="today-punch-duration-number is-hours" data-punch-timer-target="hours"><%= punch_duration[:hours] %></span><span class="today-punch-duration-unit">h</span>
          <span class="today-punch-duration-number" data-punch-timer-target="minutes"><%= punch_duration[:minutes] %></span><span class="today-punch-duration-unit">m</span>
          <span class="today-punch-duration-number" data-punch-timer-target="seconds"><%= punch_duration[:seconds] %></span><span class="today-punch-duration-unit">s</span>
        </span>
      <% end %>
    <% else %>
      <%= button_to clock_in_path,
        method: :post,
        form_class: "clock-action-form today-punch-action-form",
        class: "today-punch-button",
        data: {
          controller: "punch-timer",
          punch_timer_base_seconds_value: @today_worked_seconds,
          submitting_label: t("shared.submitting.entering")
        } do %>
        <span class="today-punch-action-row">
          <%= icon "log-in" %>
          <span class="today-punch-label"><%= t(".clock_in") %></span>
        </span>
        <span class="today-punch-duration">
          <span class="today-punch-duration-number is-hours" data-punch-timer-target="hours"><%= punch_duration[:hours] %></span><span class="today-punch-duration-unit">h</span>
          <span class="today-punch-duration-number" data-punch-timer-target="minutes"><%= punch_duration[:minutes] %></span><span class="today-punch-duration-unit">m</span>
          <span class="today-punch-duration-number" data-punch-timer-target="seconds"><%= punch_duration[:seconds] %></span><span class="today-punch-duration-unit">s</span>
        </span>
      <% end %>
    <% end %>
  </section>

  <section class="today-section today-clockings-section">
    <header class="today-section-header">
      <div class="today-section-heading-row">
        <h2><%= t(".today_clockings") %></h2>
        <%= link_to t(".correct_today"),
          new_correction_path(day: @today.iso8601),
          class: "today-correction-link" %>
      </div>
      <hr class="today-section-rule">
    </header>

    <div class="today-history-summary">
      <% if @today_swipes.empty? %>
        <p class="today-history-empty"><em><%= t(".today_clockings_empty") %></em></p>
      <% end %>

      <% if @today_summary[:swipes].any? %>
        <div class="today-swipe-list">
          <% @today_summary[:swipes].each do |swipe| %>
            <span class="<%= class_names(clocking_swipe_class(swipe), "is-#{swipe.kind}") %>">
              <%= icon clocking_icon_name(swipe.kind), title: clocking_kind_text(swipe.kind), class: "clocking-swipe-icon" %>
              <span class="clocking-swipe-time"><%= l(swipe.swipe_at, format: :hour_minute) %></span>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="today-section today-week-section">
    <header class="today-section-header">
      <h2><%= t(".week_title") %></h2>
      <hr class="today-section-rule">
    </header>

    <dl class="today-week-lines">
      <div>
        <dt><%= link_to t(".week_activity_label"), dashboard_clockings_path(@today) %></dt>
        <dd><%= link_to weekly_activity_text(@week_summary), dashboard_clockings_path(@today) %></dd>
      </div>
      <div>
        <dt><%= link_to t(".week_corrections_label"), dashboard_corrections_path(@today) %></dt>
        <dd>
          <% if weekly_corrections_empty?(@week_summary) %>
            <%= link_to dashboard_corrections_path(@today) do %>
              <em><%= weekly_corrections_text(@week_summary) %></em>
            <% end %>
          <% else %>
            <% weekly_correction_parts(@week_summary).each_with_index do |part, index| %>
              <%= ", " if index.positive? %><%= link_to part[:text], dashboard_corrections_path(@today, status: part[:status]) %>
            <% end %>
          <% end %>
        </dd>
      </div>
    </dl>
  </section>
</div>
