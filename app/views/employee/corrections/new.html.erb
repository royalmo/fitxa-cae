<% content_for :title, t(".title") %>

<section class="page-intro">
  <div>
    <h1 class="page-title"><%= icon "square-pen", class: "icon-large" %><span><%= t(".heading") %></span></h1>
  </div>
</section>

<%= render "layouts/flash_messages", class: "employee-page-flash" %>

<section class="correction-form-section">
  <%= render "layouts/error_summary", errors: @correction.errors, title: t(".error_title") %>

  <%= form_with url: corrections_path,
    class: "stacked-form correction-form",
    data: {
      controller: "correction-form",
      correction_form_day_url_value: day_corrections_path,
      correction_form_entries_label_value: t(".entries"),
      correction_form_exits_label_value: t(".exits"),
      correction_form_request_entry_label_value: t(".request_entry"),
      correction_form_request_exit_label_value: t(".request_exit"),
      correction_form_existing_swipes_label_value: t(".existing_swipes"),
      correction_form_entry_icon_value: icon("log-in", class: "correction-existing-swipe-kind-icon"),
      correction_form_exit_icon_value: icon("log-out", class: "correction-existing-swipe-kind-icon"),
      correction_form_keep_swipe_label_value: t(".keep_swipe"),
      correction_form_remove_swipe_label_value: t(".remove_swipe"),
      correction_form_keep_swipe_icon_value: icon("rotate-ccw", class: "correction-existing-swipe-state-icon"),
      correction_form_remove_swipe_icon_value: icon("trash-2", class: "correction-existing-swipe-state-icon"),
      action: "input->correction-form#dismissErrors change->correction-form#dismissErrors"
    } do |form| %>
    <div class="field">
      <%= form.label :date, t(".date") %>
      <%= form.date_field :date,
        value: @form_day&.iso8601,
        min: @correction_date_range.begin.iso8601,
        max: @correction_date_range.end.iso8601,
        data: {
          correction_form_target: "date",
          action: "change->correction-form#loadDay"
        } %>
    </div>

    <div class="correction-select-day-state" data-correction-form-target="emptyPrompt" <%= "hidden" if @form_has_day %>>
      <%= icon "square-pen", class: "empty-state-icon" %>
      <p><%= t(".select_day_empty") %></p>
    </div>

    <div class="correction-select-day-state correction-loading-state" data-correction-form-target="loadingPrompt" hidden>
      <span class="submit-spinner correction-loading-spinner" aria-hidden="true"></span>
      <p><%= t(".loading_day") %></p>
    </div>

    <div class="correction-form-details" data-correction-form-target="formContent" <%= "hidden" unless @form_has_day %>>
      <p class="correction-pending-note" data-correction-form-target="pendingNotice" <%= "hidden" unless @pending_correction %>>
        <%= icon "info", class: "correction-pending-note-icon" %>
        <span><%= t(".pending_loaded") %></span>
      </p>

      <fieldset class="correction-day-section" aria-label="<%= t(".existing_swipes") %>">
        <div class="correction-existing-swipes" data-correction-form-target="existingSwipes">
          <div class="correction-swipe-table" role="table" aria-label="<%= t(".existing_swipes") %>">
            <div class="correction-swipe-table-header" role="row">
              <span role="columnheader"><%= t(".entries") %></span>
              <span role="columnheader"><%= t(".exits") %></span>
            </div>

            <% clocking_swipe_rows(@day_swipes).each do |swipe_row| %>
              <div class="correction-swipe-table-row" role="row">
                <% [ :entry, :exit ].each do |kind| %>
                  <div class="correction-swipe-table-cell" role="cell">
                    <% if (swipe = swipe_row[kind]) %>
                      <label class="correction-existing-swipe" data-kind="<%= swipe.kind %>">
                        <%= check_box_tag "invalidated_swipe_ids[]", swipe.id, @invalidated_swipe_ids.include?(swipe.id.to_s), class: "sr-only" %>
                        <span class="correction-existing-swipe-main">
                          <%= icon clocking_icon_name(swipe.kind), title: clocking_kind_text(swipe.kind), class: "correction-existing-swipe-kind-icon" %>
                          <span class="correction-existing-swipe-copy">
                            <strong><%= l(swipe.swipe_at, format: :hour_minute) %></strong>
                          </span>
                        </span>
                        <span class="correction-existing-swipe-state">
                          <span class="correction-existing-swipe-keep" title="<%= t(".remove_swipe") %>" aria-label="<%= t(".remove_swipe") %>">
                            <%= icon "trash-2", class: "correction-existing-swipe-state-icon" %>
                          </span>
                          <span class="correction-existing-swipe-remove" title="<%= t(".keep_swipe") %>" aria-label="<%= t(".keep_swipe") %>">
                            <%= icon "rotate-ccw", class: "correction-existing-swipe-state-icon" %>
                          </span>
                        </span>
                      </label>
                    <% else %>
                      <span class="correction-swipe-empty-slot" aria-hidden="true">—</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="correction-swipe-table-row correction-swipe-request-row" role="row">
              <div class="correction-swipe-table-cell" role="cell">
                <label class="correction-requested-swipe" data-kind="entry">
                  <%= icon "log-in", title: clocking_kind_text(:entry), class: "correction-requested-swipe-icon" %>
                  <%= hidden_field_tag "requested_swipes[][kind]", "entry" %>
                  <%= time_field_tag "requested_swipes[][time]",
                    @requested_swipes_by_kind.dig("entry", "time").to_s.first(5),
                    aria: { label: t(".request_entry") } %>
                </label>
              </div>
              <div class="correction-swipe-table-cell" role="cell">
                <label class="correction-requested-swipe" data-kind="exit">
                  <%= icon "log-out", title: clocking_kind_text(:exit), class: "correction-requested-swipe-icon" %>
                  <%= hidden_field_tag "requested_swipes[][kind]", "exit" %>
                  <%= time_field_tag "requested_swipes[][time]",
                    @requested_swipes_by_kind.dig("exit", "time").to_s.first(5),
                    aria: { label: t(".request_exit") } %>
                </label>
              </div>
            </div>
          </div>
        </div>
      </fieldset>

      <div class="field">
        <%= form.label :note, t(".note") %>
        <%= form.text_area :note,
          rows: 5,
          value: @requester_comments,
          placeholder: t(".note_placeholder"),
          data: { correction_form_target: "comment" } %>
      </div>

      <div class="form-actions correction-form-actions">
        <div class="correction-delete-action" data-correction-form-target="deleteAction" <%= "hidden" unless @pending_correction %>>
          <%= link_to(@pending_correction ? correction_path(@pending_correction) : "#",
            class: "button correction-delete-button",
            data: {
              correction_form_target: "deleteLink",
              turbo_method: :delete
            }) do %>
            <%= icon "trash-2" %>
            <span><%= t(".delete") %></span>
          <% end %>
        </div>

        <div class="correction-submit-actions">
          <%= link_to corrections_path, class: "button button-secondary" do %>
            <%= icon "x" %>
            <span><%= t("shared.cancel") %></span>
          <% end %>
          <%= button_tag type: :submit, class: "button button-primary", data: { submitting_label: t("shared.submitting.sending") } do %>
            <%= icon "send" %>
            <span><%= t(".submit") %></span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>
