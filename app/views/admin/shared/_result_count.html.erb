<p class="admin-result-count small text-body-secondary fw-semibold" data-list-loading-target="results">
  <% if count.positive? %>
    <%= t("admin.pagination.showing_count", from: range_start, to: range_end, count: count) %>
  <% else %>
    <%= t("admin.pagination.empty_count") %>
  <% end %>
</p>
